# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key

# Pinecone Database Credentials
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_PAPERS=kongdang-papers
PINECONE_INDEX_WELFARE=kongdang-welfare

# Supabase Credentials (Public client-side keys)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# PubMed E-utilities API Key (Optional but recommended to avoid rate limits)
PUBMED_API_KEY=your_pubmed_api_key

# NextAuth Authentication Credentials
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
